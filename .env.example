# Copy this file to ".env" in THIS folder (Smart-CSM/), not CSM/ or server_ai/.
# After editing .env: restart "npm run dev" AND the Python server (uvicorn).

# --- Frontend (Vite) — only VITE_* are exposed to the browser ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the project's anon / publishable key (often starts with eyJ or sb_publishable_)
VITE_SUPABASE_ANON_KEY=

# Optional: AI / notify backend (defaults shown in code if unset)
# VITE_AI_SERVER_URL=http://localhost:8000
# VITE_CSM_AI_SECRET=csm_secure_ai_access_2024

VITE_GEMINI_API_KEY=
VITE_RECAPTCHA_SITE_KEY=
VITE_GOOGLE_CLIENT_ID=

# --- Server / scripts only (never VITE_ prefix for secrets) ---
SUPABASE_SERVICE_ROLE_KEY=

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

SUPABASE_DB_PASSWORD=
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

HTTPSMS_API_KEY=
HTTPSMS_FROM_NUMBER=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SENDER_EMAIL=

# Optional override for FastAPI notify routes (must match VITE_CSM_AI_SECRET if set)
# CSM_API_SECRET=csm_secure_ai_access_2024
